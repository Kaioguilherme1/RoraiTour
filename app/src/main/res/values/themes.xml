<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.RoraiTour" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/ios_blue</item>
        <item name="android:windowBackground">@color/ios_system_background</item>
        <item name="android:statusBarColor">@color/ios_system_background</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Shape appearance -->
        <item name="shapeAppearanceCornerExtraLarge">@style/ShapeAppearance.App.Corner.Large</item>
    </style>

    <style name="Theme.RoraiTour" parent="Base.Theme.RoraiTour" />

    <style name="ShapeAppearance.App.Corner.Large" parent="ShapeAppearance.Material3.Corner.ExtraLarge">
        <item name="cornerSize">20dp</item>
    </style>

    <style name="ShapeAppearance.App.Corner.TopOnly" parent="ShapeAppearance.Material3.Corner.ExtraLarge">
        <item name="cornerSizeTopLeft">24dp</item>
        <item name="cornerSizeTopRight">24dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <!-- iOS Style Card -->
    <style name="Widget.App.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/ios_card_background</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="android:layout_margin">8dp</item>
    </style>
</resources>
